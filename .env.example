# This project uses Doppler for secrets — there is NO .env file.
# This file documents which variable names the project expects.
# Run `doppler setup` to link the project to Doppler, then `npm run dev`.
DATABASE_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=
NODE_ENV=
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
ANIMAL_FARM_SHEET_ID=
